# Evermark Bot Configuration
# Copy these variables to your .env file after setting up the bot

# Existing Neynar API key (already configured)
NEYNAR_API_KEY=your_existing_neynar_api_key

# Bot Account Details (get these from Farcaster.xyz)
EVERMARK_BOT_FID=123456
EVERMARK_BOT_USERNAME=evermarkbot
EVERMARK_BOT_SIGNER_UUID=your_signer_uuid_from_neynar_dashboard

# Webhook Security (generate a random secret)
NEYNAR_WEBHOOK_SECRET=your_random_webhook_secret

# Admin Protection (generate a random admin key)
EVERMARK_ADMIN_KEY=your_random_admin_key

# Instructions:
# 1. Create bot account at https://farcaster.xyz with username @evermarkbot
# 2. Get FID from your profile
# 3. Create signer at https://dev.neynar.com/app/agents-and-bots
# 4. Generate random secrets for webhook and admin keys
# 5. Add webhook in Neynar dashboard pointing to your deployed function